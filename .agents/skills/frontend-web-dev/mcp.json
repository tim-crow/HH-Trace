{
  "chrome-devtools": {
    "command": "npx",
    "args": ["-y", "chrome-devtools-mcp@latest"],
    "includeTools": [
      "navigate_page",
      "take_screenshot",
      "take_snapshot",
      "click",
      "fill",
      "evaluate_script",
      "list_console_messages",
      "list_network_requests",
      "resize_page"
    ]
  }
}
